# Copy to .env.local and fill in. .env.local is gitignored.
# Ticketmaster Discovery API consumer key — https://developer.ticketmaster.com
TM_API_KEY=

# Supabase (Project Settings -> API). Service-role key is server-only; never ship to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (Project Settings -> Database -> Connection string).
# Used only by `npm run db:apply` to run migrations. Keep private.
DATABASE_URL=

# Anthropic API key (console.anthropic.com) for LLM event blurbs (T8).
# Optional: ingest runs fine without it; blurbs just stay empty (page shows the title).
ANTHROPIC_API_KEY=

# Email via Resend (resend.com — free tier). Optional: signup confirm + weekly
# digest skip if RESEND_API_KEY is unset.
RESEND_API_KEY=
# DIGEST_TO: fallback recipient for the digest when there are no confirmed
# subscribers yet. On the free tier (no verified domain) this must be your
# Resend-account email — that's the only address Resend will deliver to.
DIGEST_TO=
# Senders — all default to onboarding@resend.dev (free tier). Once you verify a
# domain in Resend, set these to branded addresses on that domain and everything
# goes branded with no code change:
#   EMAIL_FROM      transactional sender (signup confirm emails)
#   DIGEST_FROM     weekly-digest sender (falls back to EMAIL_FROM)
#   EMAIL_REPLY_TO  optional Reply-To on every email
# EMAIL_FROM=ATLive <hello@yourdomain.com>
# DIGEST_FROM=ATLive Weekly <weekly@yourdomain.com>
# EMAIL_REPLY_TO=hello@yourdomain.com
