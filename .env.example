# Copy to .env.local and fill in. .env.local is gitignored.

# Public site origin (no trailing slash). Drives canonical tags, sitemap,
# robots, OG image URLs, and the links inside confirm/unsubscribe emails.
# Defaults to https://atlive.vercel.app. When a custom domain is live, set this
# to it (e.g. https://atlive.com) here AND in Vercel + GitHub Actions secrets.
NEXT_PUBLIC_SITE_URL=

# Ticketmaster Discovery API consumer key — https://developer.ticketmaster.com
TM_API_KEY=

# Supabase (Project Settings -> API). Service-role key is server-only; never ship to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (Project Settings -> Database -> Connection string).
# Used only by `npm run db:apply` to run migrations. Keep private.
DATABASE_URL=

# Anthropic API key (console.anthropic.com) for LLM event blurbs (T8).
# Optional: ingest runs fine without it; blurbs just stay empty (page shows the title).
ANTHROPIC_API_KEY=

# Waitlist mode (default ON when unset). While on, signups are stored but no
# confirm email is sent (avoids a 403 dead-end before a sending domain exists).
# Set to "false" once a Resend domain is verified to enable real double opt-in,
# then run `npm run waitlist:promote` to confirm the collected waitlist.
WAITLIST_MODE=

# Email via Resend (resend.com — free tier). Optional: signup confirm + weekly
# digest skip if RESEND_API_KEY is unset.
RESEND_API_KEY=
# DIGEST_TO: fallback recipient for the digest when there are no confirmed
# subscribers yet. On the free tier (no verified domain) this must be your
# Resend-account email — that's the only address Resend will deliver to.
DIGEST_TO=
# Senders — all default to onboarding@resend.dev (free tier). Once you verify a
# domain in Resend, set these to branded addresses on that domain and everything
# goes branded with no code change:
#   EMAIL_FROM      transactional sender (signup confirm emails)
#   DIGEST_FROM     weekly-digest sender (falls back to EMAIL_FROM)
#   EMAIL_REPLY_TO  optional Reply-To on every email
# EMAIL_FROM=ATLive <hello@yourdomain.com>
# DIGEST_FROM=ATLive Weekly <weekly@yourdomain.com>
# EMAIL_REPLY_TO=hello@yourdomain.com

# Weekly draft pack (IG + Reddit) recipient — defaults to DIGEST_TO if unset.
# The pack is emailed for MANUAL posting; nothing is auto-posted to IG/Reddit.
DRAFTS_TO=

# Auto-social (weekly GitHub Action → Bluesky + X). All optional: each platform
# posts only when its keys are present, so the job is a no-op until you add them.
# Bluesky — handle + an APP password (Settings → App Passwords, not your login):
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
# X / Twitter — app consumer key/secret + the posting account's access token/
# secret, all from developer.x.com (the app needs Read+Write permission):
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
